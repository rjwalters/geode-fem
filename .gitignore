# Visualization artifacts (geode_viz outputs — issue #277, Epic #276)
# Generated PNG / SVG plots from tools/viz/ never land in version control;
# regenerate locally with `python -m geode_viz.plots.<benchmark>`.
artifacts/

# Python build artifacts (geode_viz package)
*.egg-info/
build/
dist/
# Claude Code agent-isolation worktrees (local session state, never committed)
.claude/worktrees/

# Local credentials / secrets — never commit
.env
.env.*
!.env.example
*.local.md
/.voice/

# Repo Skills machine-local install metadata (absolute source path + timestamp)
.claude/skills/repo/.install-local.json
