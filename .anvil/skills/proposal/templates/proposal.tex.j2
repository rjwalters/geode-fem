%% proposal.tex — Anvil buildable-system proposal template
%%
%% Compile with: xelatex proposal.tex   (NOT pdflatex — see anvil-proposal.cls)
%%
%% Generated by anvil:proposal. The double-brace placeholders are substituted by
%% the drafter from the BRIEF.md frontmatter. The 10 section skeletons are
%% starting points; the drafter elaborates each into prose, tables, and figure
%% references. The section structure mirrors the canonical "Gossamer LAN" worked
%% instance (see examples/expected-thread.1/README.md).
%%
%% A proposal argues for resources to build something. Its "customer" is whoever
%% approves the commitment — an external client OR an internal budget sponsor.
%% This is the PRE-commitment bookend to anvil:report (the post-commitment
%% deliverable): proposal -> (commitment) -> report.
%%
%% Frontmatter placeholders (all optional, defaults shown):
%%   title            — system / project name
%%   subtitle         — one-line gloss
%%   studio           — author/studio name (footer + kicker)
%%   date             — proposal date
%%   stage            — title-block stage line. Defaults from customer_kind.
%%   signature_color  — hex (no #), default 4A6FA5 (steel blue)
%%   hero             — path to hero render under figures/ (omit if none)
%%   customer_kind    — external|internal (default external). Tunes the stage
%%                      line and how the reviewer reads dim 7 (persuasiveness):
%%                      external = "wins the client"; internal = "justifies the
%%                      budget allocation". It does NOT add or remove sections.
%%   orientation      — portrait|landscape (default portrait). When landscape,
%%                      passes the `landscape` class option to anvil-proposal.cls
%%                      so the geometry package switches to landscape letter
%%                      (792 x 612 pt). Useful for table-dense proposals where
%%                      the wider text block lets columns breathe; default
%%                      portrait keeps the Gossamer LAN worked example unchanged.

\documentclass[{% if (orientation | default("portrait")) == "landscape" %}landscape{% endif %}]{anvil-proposal}

%% Signature color override (default 4A6FA5 lives in the class).
\definecolor{accent}{HTML}{ {{- signature_color | default("4A6FA5") -}} }
\definecolor{rule}{HTML}{ {{- signature_color | default("4A6FA5") -}} }

\proposaltitle{ {{- title | default("Proposal Title") -}} }
\proposalsubtitle{ {{- subtitle | default("") -}} }
\proposalstudio{ {{- studio | default("Studio") -}} }
\proposaldate{ {{- date | default("\\today") -}} }
%% The stage line defaults from customer_kind: an external pitch is at "CONCEPT
%% STAGE"; an internal build spec is labelled as such. An explicit `stage` in the
%% brief overrides either default.
\proposalstage{ {{- stage | default("DESIGN PROPOSAL --- CONCEPT STAGE" if (customer_kind | default("external")) == "external" else "INTERNAL BUILD SPEC") -}} }

\begin{document}

\maketitleblock

%% Hero image (full-width, optional). Drop the render into figures/ and name it
%% in the brief's `hero:` key. Omit the key entirely for a no-hero proposal — a
%% topology diagram or site/routing plan is the most common hero for a proposal.
\herofigure{ {{- hero | default("") -}} }

%% ── 1. Premise ───────────────────────────────────────────────────────────────
%% One-paragraph thesis of the system, in a callout, threading the customer's
%% hard constraints. A reader should grasp WHAT is being built and the single
%% argument for it without further reading. Anchors rubric dimension 1 (intent /
%% requirements clarity).
\begin{callout}[title=Premise]
{{ premise | default("One paragraph: what the system is, what it delivers, and the hard constraints it satisfies (e.g. invisibility, no conduit, 10\\,Gbps). Legible without further reading.") }}
\end{callout}

%% ── 2. The Idea ──────────────────────────────────────────────────────────────
%% Why this approach; the problem the conventional answer fails to solve. The
%% pitch element lives here and in the Premise. Anchors rubric dimensions 1
%% (intent) and 7 (persuasiveness / value proposition).
\section{The Idea}

{{ idea | default("Why this approach, and what the conventional answer costs or fails to deliver. State the value proposition the approver is being asked to fund. Several paragraphs.") }}

