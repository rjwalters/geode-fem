%% datasheet.tex — Anvil IC/component datasheet template
%%
%% Compile with: xelatex datasheet.tex   (NOT pdflatex — see anvil-datasheet.cls)
%%
%% Generated by anvil:datasheet. The double-brace placeholders are substituted
%% by the drafter from the BRIEF.md frontmatter + the refs/ spec bundle. The
%% section skeletons are starting points; the drafter elaborates each into
%% tables and tight reference prose. Layout conventions baked in (issue #418
%% canary recommendation 3): two-column first page (Key Features | Applications),
%% major sections starting on a fresh page (\clearpage pre-wired), consistent
%% rev/footer block (the class's fancy footer).
%%
%% Frontmatter placeholders (all optional, defaults shown):
%%   part_number      — the part / SKU designator (headline + footer)
%%   title            — descriptive line under the part number
%%   subtitle         — one-line gloss
%%   company          — vendor name (footer + kicker)
%%   date             — sheet date
%%   rev              — revision (default 0.1; spec-touching revisions MUST bump
%%                      this AND add a Revision History row — the READY-gate)
%%   status           — preliminary|production (default preliminary). Drives the
%%                      title-block status line + the standing preliminary notice.
%%   signature_color  — hex (no #), default 1F4E7A (navy, ANVIL_NAVY)
%%   package          — package name (e.g. QFN48) for the pin-map marker
%%   package_pins     — pin count for the pin-map marker
%%
%% Integrity markers (REQUIRED on skill-authored sheets — see SKILL.md
%% §"Deterministic pre-flight"):
%%   % anvil-pinmap-begin package=<pkg> pins=<N>  ...rows...  % anvil-pinmap-end
%%   % anvil-bus: name=<field> width=<W> max=<M>   (or range=<lo>-<hi> / values=<count>)

\documentclass{anvil-datasheet}

%% Signature color override (default 1F4E7A navy lives in the class).
\definecolor{accent}{HTML}{ {{- signature_color | default("1F4E7A") -}} }
\definecolor{rule}{HTML}{ {{- signature_color | default("1F4E7A") -}} }

\datasheetpart{ {{- part_number | default("PART-0000") -}} }
\datasheettitle{ {{- title | default("Descriptive Part Title") -}} }
\datasheetsubtitle{ {{- subtitle | default("") -}} }
\datasheetcompany{ {{- company | default("Company") -}} }
\datasheetdate{ {{- date | default("\\today") -}} }
\datasheetrev{ {{- rev | default("0.1") -}} }
%% The status line defaults from `status`: preliminary sheets carry the
%% subject-to-change banner; production sheets the plain label.
\datasheetstatus{ {{- status_line | default("PRELIMINARY --- SPECIFICATIONS SUBJECT TO CHANGE" if (status | default("preliminary")) == "preliminary" else "PRODUCTION") -}} }

